# ============================================
# 火山引擎 ASR API 配置模板
# ============================================
# 
# 使用说明：
# 1. 复制此文件并重命名为 api_keys.env
# 2. 前往火山引擎控制台申请语音识别服务
# 3. 填入您的真实凭据
#
# 申请地址：https://console.volcengine.com/speech/app
# 文档地址：https://www.volcengine.com/docs/6561/80816
#
# ============================================

# APP ID（必填）- 在控制台 -> 语音技术 -> 应用管理中获取
VOLC_APP_KEY=your_app_id_here

# Access Token（必填）- 在控制台 -> Token 管理中获取
VOLC_ACCESS_KEY=your_access_token_here

# 资源 ID（可选，默认使用豆包2.0小时版）
# 豆包1.0 小时版：volc.bigasr.sauc.duration
# 豆包1.0 并发版：volc.bigasr.sauc.concurrent
# 豆包2.0 小时版：volc.seedasr.sauc.duration（推荐）
# 豆包2.0 并发版：volc.seedasr.sauc.concurrent
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration

# 快捷键配置（建议通过设置页面录制，以下为默认值）
START_HOTKEY_CODE=22
START_HOTKEY_MODS=1835008
STOP_HOTKEY_CODE=36
STOP_HOTKEY_MODS=0

# 输入模式: hold = 按住说话, toggle = 按下切换
INPUT_MODE=hold

# 按住说话快捷键（默认 fn+Control）
HOLD_HOTKEY_CODE=59
HOLD_HOTKEY_MODS=8650752
